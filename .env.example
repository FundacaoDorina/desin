# ID da planilha do Google Sheets para sincronizar o roadmap.
#
# Use o ID de PUBLICAÇÃO (recomendado):
#   1. Vá em Arquivo > Compartilhar > Publicar na Web
#   2. Selecione a aba correta e clique em "Publicar"
#   3. Copie o trecho "2PACX-..." da URL gerada:
#      https://docs.google.com/spreadsheets/d/e/2PACX-ESTE_TRECHO/pubhtml
#
# Deixe vazio ou remova para usar os dados estáticos do projects.json
VITE_GOOGLE_SHEETS_ID=

# GID da aba "scripts" quando usar ID de publicação (2PACX-...).
# Exemplo de URL publicada da aba:
#   https://docs.google.com/spreadsheets/d/e/2PACX-.../pubhtml?gid=123456789&single=true
# Nesse caso, use:
#   VITE_GOOGLE_SHEETS_SCRIPTS_GID=123456789
VITE_GOOGLE_SHEETS_SCRIPTS_GID=

# GID da aba "project_docs" quando usar ID de publicação (2PACX-...).
VITE_GOOGLE_SHEETS_DOCS_GID=
